OPENROUTER_API_KEY=your_openrouter_api_key_here
TAVILY_API_KEY=your_tavily_api_key_here

# 邮件通知（可选）：竞品雷达检测到变更时自动发邮件
# Gmail 用户须先在 Google 账户安全设置中开启「应用专用密码」
NOTIFY_EMAIL_TO=your@email.com
NOTIFY_SMTP_HOST=smtp.gmail.com
NOTIFY_SMTP_PORT=587
NOTIFY_SMTP_USER=your@gmail.com
NOTIFY_SMTP_PASS=your_app_password_here

# Webhook 通知（可选，#30）：填写任意一个即可，支持多平台同时推送
# 钉钉：群 → 智能群助手 → 添加自定义机器人，安全关键词填「竞品雷达」
NOTIFY_DINGTALK_WEBHOOK=https://oapi.dingtalk.com/robot/send?access_token=YOUR_TOKEN
# 飞书：群 → 设置 → 机器人 → 添加自定义机器人 → 复制 Webhook 地址
NOTIFY_FEISHU_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/YOUR_HOOK_ID
# Slack：工作区 → 应用 → Incoming WebHooks → Add to Slack
NOTIFY_SLACK_WEBHOOK=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK

# ─────────────────────────────────────────────────────────────
# 报告导出（可选，#26）
# ─────────────────────────────────────────────────────────────

# Notion 导出：
#   1. 访问 https://www.notion.so/my-integrations 创建 Integration
#   2. 复制 "Internal Integration Token"（ntn_xxx 或 secret_xxx）
#   3. 在 Notion 中打开目标父页面 → 右上角「...」→ 连接 → 选择你的 Integration
#   4. 复制父页面 URL 中的 32 位 ID（https://notion.so/xxxxx-32位ID）
NOTION_TOKEN=ntn_your_integration_token_here
NOTION_PARENT_PAGE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 飞书文档导出：
#   1. 访问飞书开放平台 https://open.feishu.cn/app 创建自建应用
#   2. 在「权限管理」开启：docx:document（创建、编辑飞书文档）
#   3. 发布应用后复制 App ID 和 App Secret
#   4. FEISHU_FOLDER_TOKEN 可选：在飞书云文档中打开目标文件夹，URL 末段即为 token
FEISHU_APP_ID=cli_your_app_id_here
FEISHU_APP_SECRET=your_app_secret_here
FEISHU_FOLDER_TOKEN=
